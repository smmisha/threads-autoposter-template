# Настройки приложения Meta Threads API (создается на developers.facebook.com)
THREADS_APP_ID=your_threads_app_id
THREADS_APP_SECRET=your_threads_app_secret

# Настройки вашего аккаунта Threads
THREADS_USERNAME=socialmediamisha
THREADS_USER_ID=your_threads_user_id

# Длинный токен доступа (генерируется через setup.js)
THREADS_ACCESS_TOKEN=your_long_lived_access_token

# API-ключ Gemini от Google AI Studio (aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key
